# 🏥 Hospital Archive - Environment Configuration
# Bu dosyayı .env olarak kopyala ve değerleri doldur

# ============================================================================
# API KEYS (ZORUNLU)
# ============================================================================

# OpenRouter API Key - https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-xxxxx

# Immich API Key - Kurulumdan sonra Immich Settings'den al
IMMICH_API_KEY=imch_xxxxx

# ============================================================================
# STORAGE PATHS
# ============================================================================

# Immich yükleme klasörü
UPLOAD_LOCATION=/tmp/immich-uploads

# External library (PC'den fotoğraf yüklemesi)
EXTERNAL_LIBRARY_PATH=/tmp/external

# Arşiv klasörü (eşleşmiş fotoğraflar)
ARCHIVE_PATH=/tmp/archive

# Eşleşmemiş fotoğraflar (1 saat sonra temizlenir)
UNMATCHED_PATH=/tmp/unmatched

# ============================================================================
# DATABASE
# ============================================================================

DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=immich

# ============================================================================
# n8n CONFIGURATION
# ============================================================================

N8N_USER=admin
N8N_PASSWORD=admin123

# ============================================================================
# BARCODE SERVICE
# ============================================================================

# Barkod ve fotoğraf eşleştirme için zaman penceresi (dakika)
MATCH_WINDOW_MINUTES=30

# ============================================================================
# SYSTEM
# ============================================================================

# OpenRouter Model
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct

# Timezone
TZ=Europe/Istanbul
