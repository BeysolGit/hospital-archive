# Fotograf Arsivleme - Environment Configuration
# Bu dosyayı .env olarak kopyala ve değerleri doldur

# ============================================================================
# API KEYS (ZORUNLU)
# ============================================================================

# OpenRouter API Key - https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-xxxxx

# Immich API Key - Kurulumdan sonra Immich Settings'den al
IMMICH_API_KEY=imch_xxxxx

# ============================================================================
# STORAGE PATHS
# ============================================================================

# External library (PC'den fotograf yuklemesi)
EXTERNAL_LIBRARY_PATH=./photos/external

# Arsiv klasoru (eslesmis fotograflar)
ARCHIVE_PATH=./photos/archive

# Eslesmemis fotograflar (1 saat sonra temizlenir)
UNMATCHED_PATH=./photos/unmatched

# ============================================================================
# DATABASE
# ============================================================================

DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=immich

# ============================================================================
# n8n CONFIGURATION
# ============================================================================

N8N_USER=admin
N8N_PASSWORD=admin123

# ============================================================================
# BARCODE SERVICE
# ============================================================================

# Barkod ve fotoğraf eşleştirme için zaman penceresi (dakika)
MATCH_WINDOW_MINUTES=30

# ============================================================================
# SYSTEM
# ============================================================================

# OpenRouter Model
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct

# Timezone
TZ=Europe/Istanbul
